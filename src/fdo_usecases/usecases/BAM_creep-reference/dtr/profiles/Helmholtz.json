{
  "$schema": "https://dtr.fair-infrastructure.net/schema/Profile",
  "pid": "<<PLACEHOLDER>>",
  "name": "Helmholtz",
  "description": "Helmholtz Association-specific metadata profile for classifying research outputs according to strategic research areas and program-oriented funding structures.",
  "version": "1.0.0",
  "contributor": [
    {
      "Name": "Maximilian Inckmann",
      "ORCID": "https://orcid.org/0009-0005-2800-4833"
    }
  ],
  "ExpectedUse": "Metadata enrichment for Helmholtz Association research outputs, enabling portfolio analysis, strategic reporting, and alignment with institutional research classification schemes.",
  "References": [
    "https://www.helmholtz.de/en/research/"
  ],
  "Aliases": [
    "Helmholtz Research Area Profile",
    "PoF Classification Profile"
  ],
  "Schema": {
    "Type": "Object",
    "Properties": [
      {
        "Name": "helmholtzResearchArea",
        "Title": "Helmholtz Research Area",
        "Description": "Strategic research field classification",
        "Type": "<<PLACEHOLDER_helmholtzResearchArea>>",
        "Properties": {
          "Cardinality": "1 - n"
        }
      },
      {
        "Name": "helmholtzPoFStructure",
        "Title": "Program-Oriented Funding Structure",
        "Description": "Hierarchical PoF program identifier",
        "Type": "<<PLACEHOLDER_helmholtzPoFStructure>>",
        "Properties": {
          "Cardinality": "1 - n"
        }
      }
    ]
  }
}
