          "Cardinality": "0 - 1"
        }
      },
      {
        "Name": "keyword",
        "Type": "<<PLACEHOLDER_keyword>>",
        "Properties": {
          "Cardinality": "1 - n"
        }
      },
      {
        "Name": "name",
        "Type": "<<PLACEHOLDER_name>>",
        "Properties": {
          "Cardinality": "1"
        }
      },
      {
        "Name": "description",
        "Type": "<<PLACEHOLDER_description>>",
        "Properties": {
          "Cardinality": "1"
        }
      }
    ]
